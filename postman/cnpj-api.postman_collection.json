              "host": ["{{baseUrl}}"],
              "path": ["api", "cnpj"],
              "query": [
                { "key": "cnae", "value": "{{cnae_codigo}}" },
                { "key": "porte", "value": "01", "description": "01 = Micro empresa" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Micro empresas do CNAE definido na variável de ambiente."
          },
          "response": []
        },
        {
          "name": "400 — Limit acima do máximo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cnpj?limit=200",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cnpj"],
              "query": [
                { "key": "limit", "value": "200", "description": "Máximo permitido é 100" }
