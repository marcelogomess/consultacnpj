{
  "name": "cnpj-api",
  "version": "0.1.0",
  "description": "API de consulta de dados públicos do CNPJ - Receita Federal",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config test/unit/jest.config.ts",
    "test:watch": "jest --config test/unit/jest.config.ts --watch",
    "test:e2e": "jest --config test/integration/jest-e2e.config.ts",
    "test:cov": "jest --config test/unit/jest.config.ts --coverage",
    "download": "ts-node -r tsconfig-paths/register scripts/run-download.ts",
    "import": "ts-node -r tsconfig-paths/register scripts/run-import.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.12.0",
    "axios": "^1.6.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.5.5",
    "iconv-lite": "^0.6.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "@types/unzipper": "^0.10.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^30.3.0",
    "prettier": "^3.2.5",
    "prisma": "^5.12.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.1"
  },
  "overrides": {
    "glob": "^13.0.6",
    "test-exclude": "^7.0.2"
  }
}
