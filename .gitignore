# ===================================================
# Dependências
# ===================================================
node_modules/
.pnp
.pnp.js

# ===================================================
# Build
# ===================================================
dist/
build/

# ===================================================
# Ambiente e secrets
# ===================================================
.env
.env.local
.env.development
.env.staging
.env.production
# Manter .env.example e .env.test (sem dados sensíveis)
!.env.example
!.env.test

# ===================================================
# Prisma
# ===================================================
# Migrations geradas são versionadas; apenas o client gerado fica fora
# Se quiser versionar as migrations, remova a linha abaixo
# prisma/migrations/

# ===================================================
# Logs
# ===================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ===================================================
# Cobertura de testes
# ===================================================
coverage/
.nyc_output/
lcov.info

# ===================================================
# Cache e temporários
# ===================================================
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
.next/
.nuxt/
.vuepress/dist/
.serverless/

# ===================================================
# IDEs e editores
# ===================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.DS_Store
Thumbs.db

# ===================================================
# Sistema operacional
# ===================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# ===================================================
# Docker
# ===================================================
# Volumes e dados locais do Docker (não versionar dados de BD)
docker/data/
docker/postgres-data/

# ===================================================
# Kubernetes
# ===================================================
# Secrets reais nunca devem ser versionados
k8s/overlays/prod/secrets/
k8s/overlays/staging/secrets/
*.kubeconfig

# ===================================================
# Downloads e dados importados
# ===================================================
# Arquivos da Receita Federal (GB de dados)
data/
downloads/
*.zip
*.csv
# Exceto fixtures de teste
!test/fixtures/*.csv

# ===================================================
# Misc
# ===================================================
*.pid
*.seed
*.pid.lock
.yarn-integrity
